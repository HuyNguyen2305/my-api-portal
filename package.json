{
  "name": "my-api-portal",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "src/server.js",
  "imports": {
    "#src/*": "./src/*.js",
    "#configs/*": "./src/configs/*.js",
    "#constants/*": "./src/common/constants/*.js",
    "#controllers/*": "./src/controllers/*.js",
    "#services/*": "./src/services/*.js",
    "#repositories/*": "./src/repositories/*.js",
    "#models/*": "./src/models/*.js",
    "#schemas/*": "./src/schemas/*.js",
    "#common-schemas/*": "./src/common/schemas/*.js",
    "#utils/*": "./src/utils/*.js",
    "#test/*": "./test/*"
  },
  "scripts": {
    "start": "node src/server.js",
    "start:test": "cross-env NODE_ENV=test node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "node src/db/migrate.js up",
    "migrate:rollback": "node src/db/migrate.js down",
    "migrate:test": "cross-env NODE_ENV=test node src/db/migrate.js up",
    "promote-admin": "node src/db/promote-admin.js",
    "test:db:reset": "cross-env NODE_ENV=test node src/db/reset-test-db.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --selectProjects unit",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js --selectProjects unit",
    "test:integration": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --selectProjects integration --runInBand"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/autoload": "^6.3.1",
    "@fastify/awilix": "^8.2.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/env": "^7.0.0",
    "@fastify/passport": "^3.0.2",
    "@fastify/request-context": "^7.0.0",
    "@fastify/secure-session": "^8.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "awilix": "^13.0.5",
    "dotenv": "^17.4.2",
    "fastify": "^5.10.0",
    "fastify-plugin": "^6.0.0",
    "passport": "^0.7.0",
    "passport-strategy": "^1.0.0",
    "pg": "^8.22.0",
    "sequelize": "^6.37.5"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14"
  }
}
